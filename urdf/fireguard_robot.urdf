<?xml version="1.0"?>
<robot name="fireguard_robot">

  <link name="base_link">
    <visual>
      <geometry>
        <box size="1.1 0.75 0.28"/>
      </geometry>
      <origin xyz="0 0 0.22" rpy="0 0 0"/>
      <material name="white_body">
        <color rgba="0.9 0.9 0.85 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <box size="1.1 0.75 0.28"/>
      </geometry>
      <origin xyz="0 0 0.22" rpy="0 0 0"/>
    </collision>

    <inertial>
      <mass value="15.0"/>
      <origin xyz="0 0 0.22"/>
      <inertia ixx="0.79" ixy="0" ixz="0" iyy="1.61" iyz="0" izz="2.21"/>
    </inertial>
  </link>

  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.16" length="0.08"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="black">
        <color rgba="0.02 0.02 0.02 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.16" length="0.08"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <inertia ixx="0.014" ixy="0" ixz="0" iyy="0.014" iyz="0" izz="0.025"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.42 0.16" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.16" length="0.08"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.16" length="0.08"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <inertia ixx="0.014" ixy="0" ixz="0" iyy="0.014" iyz="0" izz="0.025"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.42 0.16" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="front_caster">
    <visual>
      <geometry>
        <sphere radius="0.16"/>
      </geometry>
      <origin xyz="0 0 0"/>
      <material name="dark_gray">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.16"/>
      </geometry>
      <origin xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_caster"/>
    <origin xyz="0.45 0 0.16" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.22" length="0.16"/>
      </geometry>
      <origin xyz="0 0 0"/>
      <material name="lidar_black">
        <color rgba="0.01 0.01 0.01 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
      <origin xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.2"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.017" ixy="0" ixz="0" iyy="0.017" iyz="0" izz="0.029"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.58" rpy="0 0 0"/>
  </joint>

  <link name="foam_tank">
    <visual>
      <geometry>
        <cylinder radius="0.18" length="0.42"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="foam_white">
        <color rgba="0.85 0.85 0.8 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.18" length="0.42"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="4.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.09" ixy="0" ixz="0" iyy="0.09" iyz="0" izz="0.06"/>
    </inertial>
  </link>

  <joint name="foam_tank_joint" type="fixed">
    <parent link="base_link"/>
    <child link="foam_tank"/>
    <origin xyz="-0.22 -0.22 0.58" rpy="0 0 0"/>
  </joint>

  <link name="foam_nozzle">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.48"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <material name="nozzle_black">
        <color rgba="0.02 0.02 0.02 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.48"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.015" ixy="0" ixz="0" iyy="0.015" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="foam_nozzle_joint" type="fixed">
    <parent link="base_link"/>
    <child link="foam_nozzle"/>
    <origin xyz="0.72 0 0.36" rpy="0 0 0"/>
  </joint>

  <link name="emergency_light">
    <visual>
      <geometry>
        <cylinder radius="0.08" length="0.08"/>
      </geometry>
      <origin xyz="0 0 0"/>
      <material name="red_light">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0006" ixy="0" ixz="0" iyy="0.0006" iyz="0" izz="0.0009"/>
    </inertial>
  </link>

  <joint name="emergency_light_joint" type="fixed">
    <parent link="base_link"/>
    <child link="emergency_light"/>
    <origin xyz="0.2 0.18 0.45" rpy="0 0 0"/>
  </joint>

  <link name="front_safety_scanner">
    <visual>
      <geometry>
        <box size="0.28 0.08 0.06"/>
      </geometry>
      <origin xyz="0 0 0"/>
      <material name="safety_scanner_blue">
        <color rgba="0.0 0.2 1.0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
      <origin xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="front_safety_scanner_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_safety_scanner"/>
    <origin xyz="0.85 0 0.06" rpy="0 0 0"/>
  </joint>

  <gazebo reference="front_caster">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <gazebo reference="base_link">
    <material>Gazebo/White</material>
  </gazebo>

  <gazebo reference="left_wheel">
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <material>Gazebo/FlatBlack</material>
  </gazebo>

  <gazebo reference="right_wheel">
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <material>Gazebo/FlatBlack</material>
  </gazebo>

  <gazebo reference="foam_tank">
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="foam_nozzle">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="emergency_light">
    <material>Gazebo/Red</material>
  </gazebo>

  <gazebo>
    <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <update_rate>50</update_rate>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.84</wheel_separation>
      <wheel_diameter>0.32</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>5.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
  </gazebo>

  <gazebo reference="lidar_link">
    <sensor type="ray" name="fireguard_lidar">
      <pose>0 0 0.15 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>

      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>

        <range>
          <min>0.12</min>
          <max>8.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>

      <plugin name="gazebo_ros_lidar" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="front_safety_scanner">
    <sensor type="ray" name="front_low_safety_scanner">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>20</update_rate>

      <ray>
        <scan>
          <horizontal>
            <samples>160</samples>
            <resolution>1</resolution>
            <min_angle>-0.9</min_angle>
            <max_angle>0.9</max_angle>
          </horizontal>
        </scan>

        <range>
          <min>0.05</min>
          <max>5.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>

      <plugin name="gazebo_ros_front_low_scanner" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=/front_scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>front_safety_scanner</frame_name>
      </plugin>
    </sensor>
  </gazebo>

</robot>
